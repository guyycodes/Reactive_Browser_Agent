# Copy to .env (gitignored) and fill in real values.

# -----------------------------------------------------------------------------
# LLM provider (used by the agent service — Claude Haiku/Sonnet/Opus)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Pinned model identifiers. Override only if Anthropic renames a model or you
# need to downgrade. MASTER_PLAN §4 maps these to workflow steps:
#   Haiku   → classify
#   Sonnet  → plan, verify       (extended thinking enabled, budget 8192 / 4096)
#   Opus    → eval judge (Week 4)
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5
ANTHROPIC_MODEL_OPUS=claude-opus-4-5

# Reserved for alternate providers; unused by the agent service today.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Postgres (matches docker-compose defaults; override if you change them)
# -----------------------------------------------------------------------------
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent

# -----------------------------------------------------------------------------
# Shared Qdrant collection UUIDs
# -----------------------------------------------------------------------------
# These are the collection names the agent, RAG pipeline, and skill-card /
# runbook ingestion scripts all agree on. The filename-UUID convention in
# services/rag/src/util/queue.py routes any file dropped with one of these
# UUIDs in its name to the matching collection, with append semantics.
# Generated once for this deployment; commit the same three values to .env.
SHARED_RUNBOOKS_UUID=d96b439c-5e3d-4e25-9790-f2235ffffe26
SHARED_SKILLS_UUID=08de373f-ca2d-4e49-8ca9-5ff799ae5d40
SHARED_SELECTORS_UUID=c6cc431a-941c-4ff4-8003-55f24dcc1e4b

# -----------------------------------------------------------------------------
# WebSocket origin allowlist for /stream/:runId
# -----------------------------------------------------------------------------
# Browsers treat localhost and 127.0.0.1 as distinct origins; VS Code port
# forwarding uses 127.0.0.1, so both variants are included by default. Bearer
# tokens land Week 3 per MASTER_PLAN; until then this is our only WS auth.
ALLOWED_WS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:6080,http://127.0.0.1:6080,http://localhost:3001,http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# Target-app credentials (used by Playwright in Week 1B; never sent to the LLM)
# -----------------------------------------------------------------------------
TARGET_APP_USER=
TARGET_APP_PASSWORD=

# -----------------------------------------------------------------------------
# Hugging Face (used by services/rag for model downloads)
# -----------------------------------------------------------------------------
# NOTE: fill in with your own token. Do NOT commit a real token to git; the
# previous placeholder was a live token and should be rotated on HF.
HF_TOKEN=
